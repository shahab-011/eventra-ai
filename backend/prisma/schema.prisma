// Eventra — Full Database Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ──────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  name                String
  phone               String?
  role                UserRole  @default(BUSINESS)
  googleId            String?   @unique
  emailVerified       Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  studio              Studio?
  teamMembers         TeamMember[]
  sessions            Session[]
  auditLogs           AuditLog[]
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS
  GUEST
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique  // stores SHA-256 hash of the raw refresh token
  expiresAt DateTime
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Audit Log ─────────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  action    AuditAction
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum AuditAction {
  SIGNUP
  LOGIN
  LOGIN_FAILED
  LOGOUT
  TOKEN_REFRESH
  OAUTH_LOGIN
  ACCOUNT_LOCKED
  OTP_REQUESTED
  OTP_VERIFIED
  OTP_FAILED
  EVENT_TRANSFER
  MEDIA_DOWNLOAD
}

// ─── Studio / Business ─────────────────────────────────────────

model Studio {
  id                  String   @id @default(uuid())
  ownerId             String   @unique
  name                String
  tagline             String?
  logoUrl             String?
  primaryColor        String   @default("#7c3aed")
  accentColor         String   @default("#43e5b1")
  watermarkEnabled    Boolean  @default(true)
  watermarkUrl        String?
  defaultGalleryTheme String   @default("dark")
  customDomain        String?  @unique
  domainVerified      Boolean  @default(false)
  subdomain           String   @unique
  planTier            PlanTier @default(MINI)
  storageUsedGB       Float    @default(0)
  storageLimitGB      Float    @default(25)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  owner              User     @relation(fields: [ownerId], references: [id])
  events             Event[]
  teamMembers        TeamMember[]
  pixels             TrackingPixel[]
  whatsappTemplates  WhatsAppTemplate[]
  automationRules    AutomationRule[]
}

enum PlanTier {
  FREE
  MINI
  SMALL
  MID
  LARGE
  ENTERPRISE
}

// ─── Team ──────────────────────────────────────────────────────

model TeamMember {
  id        String     @id @default(uuid())
  studioId  String
  userId    String
  role      TeamRole   @default(VIEWER)
  status    MemberStatus @default(PENDING)
  invitedAt DateTime   @default(now())
  joinedAt  DateTime?

  studio    Studio     @relation(fields: [studioId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studioId, userId])
}

enum TeamRole {
  OWNER
  ADMIN
  SHOOTER
  EDITOR
  VIEWER
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

// ─── Events ────────────────────────────────────────────────────

model Event {
  id              String      @id @default(uuid())
  studioId        String
  name            String
  type            EventType   @default(WEDDING)
  status          EventStatus @default(UPCOMING)
  startDate       DateTime
  endDate         DateTime?
  venue           String?
  description     String?
  guestLimit      Int         @default(300)
  storageAllocGB  Float       @default(25)
  storageUsedGB   Float       @default(0)
  galleryTheme    String      @default("dark")
  downloadEnabled Boolean     @default(true)
  downloadPin     String?
  isPublic        Boolean     @default(true)
  inviteToken     String      @unique @default(uuid())
  faceThreshold   Float       @default(0.38)
  transferredAt   DateTime?
  transferredToId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  studio          Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  subEvents       SubEvent[]
  guests          Guest[]
  media           Media[]
  qrCodes         QRCode[]
  pixels          EventPixel[]
  invites         Invite[]
  galleryTokens     GalleryToken[]
  editJobs          EditJob[]
  whatsappMessages  WhatsAppMessage[]
}

enum EventType {
  WEDDING
  CORPORATE
  BIRTHDAY
  COLLEGE_FEST
  CONCERT
  MARATHON
  OTHER
}

enum EventStatus {
  UPCOMING
  LIVE
  COMPLETED
  ARCHIVED
}

// ─── Sub-Events ────────────────────────────────────────────────

model SubEvent {
  id          String        @id @default(uuid())
  eventId     String
  name        String
  ceremonyType CeremonyType @default(CUSTOM)
  date        DateTime
  venue       String?
  guestAccess GuestAccess   @default(ALL)
  status      EventStatus   @default(UPCOMING)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())

  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  media       Media[]
  qrCodes     QRCode[]
}

enum CeremonyType {
  HALDI
  MEHENDI
  SANGEET
  WEDDING
  RECEPTION
  ENGAGEMENT
  ROKA
  CUSTOM
}

enum GuestAccess {
  ALL
  VIP
  PRIVATE
}

// ─── Guests ────────────────────────────────────────────────────

model Guest {
  id              String      @id @default(uuid())
  eventId         String
  name            String?
  phone           String
  whatsappOptIn   Boolean     @default(false)
  selfieUrl       String?
  faceEmbedding   Json?
  rsvpStatus      RsvpStatus  @default(PENDING)
  guestType       GuestType   @default(STANDARD)
  photosReceived  Int         @default(0)
  lastNotifiedAt  DateTime?
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())

  event           Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photoSelections  PhotoSelection[]
  whatsappMessages WhatsAppMessage[]
  faceVector       GuestFaceVector?
  galleryTokens    GalleryToken[]
  faceTags         FaceTag[]

  @@unique([eventId, phone])
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum GuestType {
  STANDARD
  VIP
  HOST
}

// ─── Media ─────────────────────────────────────────────────────

model Media {
  id              String      @id @default(uuid())
  eventId         String
  subEventId      String?
  uploadedBy      String?
  filename        String
  originalUrl     String
  thumbnailUrl    String?
  processedUrl    String?
  mimeType        String
  sizeBytes       BigInt
  key             String      @default("")
  status          MediaStatus @default(UPLOADING)
  wmUrl           String?
  width           Int?
  height          Int?
  takenAt         DateTime?
  aiProcessed     Boolean     @default(false)
  aiEdited        Boolean     @default(false)
  cullStatus      CullStatus  @default(NONE)
  pHash           String?
  isPrivate       Boolean     @default(false)
  uploadSource    UploadSource @default(CAMERA2CLOUD)
  createdAt       DateTime    @default(now())

  event           Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subEvent        SubEvent?   @relation(fields: [subEventId], references: [id])
  faceTags        FaceTag[]
  faceVectors     FaceVector[]
  selections      PhotoSelection[]
}

enum CullStatus {
  NONE
  KEEP
  SUGGESTED_REJECT
  REJECTED
}

enum UploadSource {
  CAMERA2CLOUD
  DESKTOP_UPLOADER
  GUEST_UPLOAD
  MANUAL
}

enum MediaStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

// ─── Face Recognition ──────────────────────────────────────────

model FaceTag {
  id           String       @id @default(uuid())
  mediaId      String
  guestId      String?
  faceVectorId String?
  boundingBox  Json
  confidence   Float
  reviewStatus ReviewStatus @default(PENDING)
  createdAt    DateTime     @default(now())

  media        Media        @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  guest        Guest?       @relation(fields: [guestId], references: [id], onDelete: SetNull)
  faceVector   FaceVector?  @relation(fields: [faceVectorId], references: [id], onDelete: SetNull)
}

enum ReviewStatus {
  PENDING
  CONFIRMED
  REJECTED
}

model FaceVector {
  id         String   @id @default(uuid())
  mediaId    String
  eventId    String
  bbox       Json
  quality    Float
  detScore   Float    @default(0)
  embedding  Unsupported("vector(512)")
  createdAt  DateTime @default(now())

  media      Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  faceTags   FaceTag[]

  @@index([eventId])
}

model GuestFaceVector {
  id        String   @id @default(uuid())
  guestId   String   @unique
  eventId   String
  embedding Unsupported("vector(512)")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model GalleryToken {
  id        String   @id @default(uuid())
  eventId   String
  guestId   String
  token     String   @unique @default(uuid())
  expiresAt DateTime
  scope     String   @default("gallery")
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([eventId])
}

// ─── Client Proofing ───────────────────────────────────────────

model PhotoSelection {
  id          String          @id @default(uuid())
  mediaId     String
  guestId     String
  type        SelectionType   @default(SELECTED)
  comment     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  media       Media           @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  guest       Guest           @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([mediaId, guestId])
}

enum SelectionType {
  SELECTED
  FAVORITED
  FLAGGED
}

// ─── QR Codes ──────────────────────────────────────────────────

model QRCode {
  id          String      @id @default(uuid())
  studioId    String?
  eventId     String?
  subEventId  String?
  label       String
  url         String
  qrColor     String      @default("#7c3aed")
  bgColor     String      @default("#15121b")
  scanCount   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  event       Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subEvent    SubEvent?   @relation(fields: [subEventId], references: [id])
}

// ─── WhatsApp ──────────────────────────────────────────────────

model WhatsAppMessage {
  id                  String          @id @default(uuid())
  guestId             String
  eventId             String?
  type                MessageType
  templateId          String?
  templateName        String?
  templateComponents  Json?
  body                String?
  status              MessageStatus   @default(QUEUED)
  waMessageId         String?
  errorData           Json?
  sentAt              DateTime?
  deliveredAt         DateTime?
  readAt              DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  guest       Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)
  event       Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

enum MessageType {
  INVITE
  RSVP_CONFIRMATION
  PHOTO_READY
  ITINERARY_REMINDER
  GALLERY_LINK
  CUSTOM
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

// ─── Invites ───────────────────────────────────────────────────

model Invite {
  id           String    @id @default(uuid())
  eventId      String
  templateId   String
  title        String
  subtitle     String?
  hostName     String?
  rsvpByDate   DateTime?
  note         String?
  shareUrl     String?
  viewCount    Int       @default(0)
  rsvpCount    Int       @default(0)
  createdAt    DateTime  @default(now())

  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ─── Tracking Pixels ───────────────────────────────────────────

model TrackingPixel {
  id          String        @id @default(uuid())
  studioId    String
  name        String
  platform    PixelPlatform
  pixelId     String
  isActive    Boolean       @default(true)
  fireCount   Int           @default(0)
  createdAt   DateTime      @default(now())

  studio      Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  eventPixels EventPixel[]
}

model EventPixel {
  id       String        @id @default(uuid())
  eventId  String
  pixelId  String

  event    Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pixel    TrackingPixel @relation(fields: [pixelId], references: [id], onDelete: Cascade)

  @@unique([eventId, pixelId])
}

enum PixelPlatform {
  META
  GOOGLE
}

// ─── Print Store Orders ────────────────────────────────────────

model Order {
  id          String      @id @default(uuid())
  eventId     String
  guestPhone  String
  guestName   String?
  items       Json
  totalAmount Int
  currency    String      @default("INR")
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── Camera Accounts ───────────────────────────────────────────

model CameraAccount {
  id               String        @id @default(uuid())
  studioId         String
  eventId          String?
  subEventId       String?
  name             String
  model            String?
  apiKey           String        @unique @default(uuid())
  ftpUsername      String        @unique
  ftpPassword      String
  status           CameraStatus  @default(DISCONNECTED)
  lastHeartbeatAt  DateTime?
  lastUploadAt     DateTime?
  uploadCount      Int           @default(0)
  createdAt        DateTime      @default(now())
}

enum CameraStatus {
  CONNECTED
  DISCONNECTED
  PAIRING
}

// ─── AI Editing Jobs ───────────────────────────────────────────

model EditJob {
  id          String        @id @default(uuid())
  eventId     String
  type        EditJobType
  status      EditJobStatus @default(PENDING)
  total       Int           @default(0)
  done        Int           @default(0)
  failed      Int           @default(0)
  lut         String?
  params      Json?
  bullJobId   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  event       Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

enum EditJobType {
  AUTO_EDIT
  AUTO_CULL
}

enum EditJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// ─── WhatsApp Templates & Automation ──────────────────────────

model WhatsAppTemplate {
  id          String           @id @default(uuid())
  studioId    String
  name        String           // Meta-approved template name, e.g. "eventra_invite_v1"
  displayName String
  language    String           @default("en_US")
  category    TemplateCategory @default(UTILITY)
  headerText  String?
  body        String           // Body text with {{1}} {{2}} placeholders
  footerText  String?
  variables   String[]         // Ordered variable descriptions for UI
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  studio      Studio           @relation(fields: [studioId], references: [id], onDelete: Cascade)
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

model AutomationRule {
  id           String      @id @default(uuid())
  studioId     String
  name         String
  trigger      AutoTrigger
  messageType  MessageType @default(INVITE)
  templateName String?     // Meta template name to use
  offsetHours  Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  studio       Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
}

enum AutoTrigger {
  GUEST_ADDED
  EVENT_START
  AFTER_EVENT
  PHOTO_READY
}
