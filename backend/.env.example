# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/eventra_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Storage (Cloudflare R2 or AWS S3)
STORAGE_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID="your-access-key"
STORAGE_SECRET_ACCESS_KEY="your-secret-key"
STORAGE_BUCKET_NAME="eventra-media"
STORAGE_PUBLIC_URL="https://media.eventra.ai"

# WhatsApp Business API
WHATSAPP_API_URL="https://graph.facebook.com/v19.0"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"

# AI Face Recognition Service (internal or external)
FACE_RECOGNITION_API_URL="http://localhost:8000"
FACE_RECOGNITION_API_KEY="your-face-api-key"

# Email (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@eventra.ai"
SMTP_PASS="your-smtp-password"
